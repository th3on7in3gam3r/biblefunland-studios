{
  "redirects": [
    {
      "source": "/services",
      "destination": "/services.html",
      "permanent": true
    },
    {
      "source": "/case-studies",
      "destination": "/case-studies.html",
      "permanent": true
    },
    {
      "source": "/brands",
      "destination": "/brand/index.html",
      "permanent": true
    },
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/$%7BpostUrl%7D",
      "destination": "/blog.html",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/blog/:slug",
      "destination": "/post.html"
    }
  ]
}
